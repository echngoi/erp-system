# ══════════════════════════════════════════════════════════
# Production Environment Variables
# Copy this file to .env.production and fill in real values
# ══════════════════════════════════════════════════════════

# ── Django Core ──
DEBUG=False
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
ALLOWED_HOSTS=YOUR_DOMAIN.com,www.YOUR_DOMAIN.com

# ── Database (auto-set by docker-compose, override if external) ──
# DATABASE_URL=postgres://erp:password@db:5432/erp

# ── Redis ──
# REDIS_URL=redis://redis:6379/0

# ── CORS (Vercel frontend domain) ──
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://YOUR_DOMAIN.com

# ── ZKTeco Device (ADMS mode — device pushes to server) ──
ZK_DEVICE_IP=0.0.0.0
ZK_DEVICE_PORT=5005
ZK_DEVICE_TIMEOUT=10
ZK_DEVICE_PASSWORD=0
ZK_PROTOCOL=adms

# ── Docker Compose (used by docker-compose.yml) ──
DB_NAME=erp
DB_USER=erp
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
